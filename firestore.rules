rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Usernames map for uniqueness and lookup
    match /usernames/{username} {
      function isValidUsernameEntry(data) {
        return data.keys().hasAll(['uid', 'email', 'username', 'photoURL']) &&
               data.keys().size() == 4 &&
               data.uid is string && data.uid.size() <= 128 &&
               data.email is string && data.email.size() <= 256 &&
               data.username is string && data.username.size() <= 50 &&
               data.photoURL is string && data.photoURL.size() <= 2000000;
      }

      allow read: if true;
      allow create: if isSignedIn() && isValidUsernameEntry(incoming()) && incoming().uid == request.auth.uid;
      allow update: if isOwner(existing().uid) && isValidUsernameEntry(incoming()) && incoming().uid == request.auth.uid;
      allow delete: if isOwner(existing().uid);
    }

    // User profile data
    match /users/{userId} {
      function isValidUserProfile(data) {
        return data.username is string && data.username.size() <= 50 &&
               data.email is string && data.email.size() <= 256 &&
               data.photoURL is string && data.photoURL.size() <= 2000000 &&
               data.createdAt is string &&
               (data.get('isGoogle', false) is bool);
      }

      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && (
        // Prevent changing immutable fields or allow specific updates
        incoming().createdAt == existing().createdAt
      );
      allow delete: if isOwner(userId);
    }
  }
}
